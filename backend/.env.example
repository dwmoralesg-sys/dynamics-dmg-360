# ---- Base de datos ----
DATABASE_URL="postgresql://dmg_admin:dmg_password@localhost:5432/dynamics_dmg_360?schema=public"

# ---- API ----
PORT=4000
NODE_ENV=development

# ---- Seguridad / JWT ----
# Genera una clave larga y aleatoria en producción:  openssl rand -hex 48
JWT_SECRET="cambia-esta-clave-por-una-larga-y-aleatoria"
JWT_EXPIRES_IN="1d"

# Sal adicional para hashear IPs en analítica (privacidad)
ANALYTICS_IP_SALT="cambia-esta-sal"

# ---- CORS ----
FRONTEND_URL="http://localhost:3000"

# ---- Usuario administrador inicial (seed) ----
SEED_ADMIN_EMAIL="admin@dynamicsdmg360.com"
SEED_ADMIN_PASSWORD="Admin.360Seguro"
SEED_ADMIN_NOMBRE="Administrador DMG"
